generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ContentStatus {
  IDEA
  DRAFT
  READY
  PUBLISHED
}

enum ContentType {
  DID_YOU_KNOW
  INFOGRAPHIC
  AUTHOR_BOOK
  QUIZ
  HISTORY
  ANALYSIS
  DAILY_HEADLINES
}

enum Language {
  ES
  EN
}

enum VideoStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum VideoDraftStatus {
  DRAFT
  SCRIPT_READY
  PREVIEW_READY
  APPROVED
  RENDERED
  SCHEDULED
  PUBLISHED
}

enum PublicationPlatform {
  LINKEDIN
  FACEBOOK
}

enum SocialConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
  DISCONNECTED
}

enum SocialAccountType {
  MEMBER
  ORGANIZATION
  PAGE
}

enum PublicationStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String?
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  contents     Content[]
  socialConnections SocialConnection[]
}

model Content {
  id            String            @id @default(uuid())
  title         String
  objective     String
  topic         String
  contentType   ContentType
  bodyText      String
  source        String
  imageUrl      String?
  status        ContentStatus     @default(IDEA)
  language      Language
  scheduledAt   DateTime?
  publishedAt   DateTime?
  metrics       Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  createdById   String
  createdBy     User              @relation(fields: [createdById], references: [id])
  videos        VideoGeneration[]
  videoDrafts   VideoDraft[]
  publicationJobs PublicationJob[]
}

model Template {
  id               String      @id @default(uuid())
  name             String
  contentType      ContentType
  description      String
  defaultStructure Json
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Source {
  id        String   @id @default(uuid())
  name      String
  url       String
  category  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoGeneration {
  id            String      @id @default(uuid())
  contentId     String
  content       Content     @relation(fields: [contentId], references: [id])
  videoDraftId  String?
  videoDraft    VideoDraft? @relation(fields: [videoDraftId], references: [id])
  promptUsed    String
  scriptUsed    String
  provider      String
  externalJobId String?
  status        VideoStatus
  videoUrl      String?
  errorMessage  String?
  subtitlesText String?
  voiceoverText String?
  providerMetadata Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([contentId])
  @@index([videoDraftId])
  @@index([status])
  @@index([externalJobId])
}

model VideoDraft {
  id                    String           @id @default(uuid())
  contentId             String
  content               Content          @relation(fields: [contentId], references: [id])
  formatProfile         Json
  hook                  String
  sections              Json
  fullScript            String
  subtitlesText         String
  subtitlesSegments     Json
  voiceoverText         String
  visualPrompt          String
  sceneDirections       Json
  brandingHints         Json?
  targetDurationSeconds Int
  targetAspectRatio     String
  voiceStyle            String
  visualStyle           String
  status                VideoDraftStatus @default(SCRIPT_READY)
  approvedAt            DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  videoGenerations      VideoGeneration[]

  @@index([contentId])
  @@index([status])
}

model PublicationJob {
  id            String              @id @default(uuid())
  contentId     String
  content       Content             @relation(fields: [contentId], references: [id])
  platform      PublicationPlatform
  socialConnectionId String?
  socialConnection SocialConnection? @relation(fields: [socialConnectionId], references: [id])
  scheduledAt   DateTime
  status        PublicationStatus
  externalPostId String?
  externalPostUrl String?
  errorMessage  String?
  payloadSnapshot Json?
  attemptCount  Int                 @default(0)
  lastAttemptAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([contentId])
  @@index([socialConnectionId])
  @@index([status])
  @@index([platform])
}

model SocialConnection {
  id                    String                 @id @default(uuid())
  userId                String
  user                  User                   @relation(fields: [userId], references: [id])
  platform              PublicationPlatform
  accountType           SocialAccountType
  accountId             String
  accountUrn            String?
  accountName           String
  accessToken           String
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scopes                Json?
  metadata              Json?
  status                SocialConnectionStatus @default(ACTIVE)
  lastSyncedAt          DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  publicationJobs       PublicationJob[]

  @@unique([userId, platform, accountId])
  @@index([userId, platform, status])
}
